{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "UV_LINK_MODE": "copy"
    }
  },
  "functions": {
    "api/fetch-snapshot.js": {
      "maxDuration": 60
    },
    "api/fetch-npp.js": {
      "maxDuration": 30
    },
    "api/fetch-cea-re.js": {
      "maxDuration": 30
    },
    "api/fetch-cea-monthly.js": {
      "maxDuration": 45
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, x-cron-secret"
        }
      ]
    }
  ]
}