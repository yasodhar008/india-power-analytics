{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "functions": {
    "api/fetch-snapshot.js":    { "maxDuration": 60,  "memory": 1024 },
    "api/fetch-npp.js":         { "maxDuration": 30,  "memory": 512 },
    "api/fetch-cea-re.js":      { "maxDuration": 30,  "memory": 512 },
    "api/fetch-cea-monthly.js": { "maxDuration": 45,  "memory": 512 }
  },
  "crons": [
    {
      "path": "/api/fetch-snapshot?snapshot=08:00",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/fetch-snapshot?snapshot=13:00",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/fetch-snapshot?snapshot=18:00",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/fetch-cea-re",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/fetch-npp",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/fetch-cea-monthly",
      "schedule": "0 6 1 * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-cron-secret" }
      ]
    }
  ]
}
